# ── RTMemory Docker Compose Environment ──────────────────────────────
# Copy this file to .env and customize values before running docker compose up.

# PostgreSQL
POSTGRES_DB=rtmemory
POSTGRES_USER=rtmemory
POSTGRES_PASSWORD=secret

# Database URL (used by alembic and the app)
RTMEM_DATABASE_URL=postgresql+asyncpg://rtmemory:secret@postgres:5432/rtmemory

# LLM Provider: openai | anthropic | ollama
RTMEM_LLM_PROVIDER=ollama
RTMEM_LLM_MODEL=qwen2.5:7b
RTMEM_LLM_BASE_URL=http://ollama:11434
# RTMEM_LLM_API_KEY=sk-...

# Embedding Provider: local | openai
RTMEM_EMBEDDING_PROVIDER=local
RTMEM_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
RTMEM_EMBEDDING_VECTOR_DIMENSION=768
# RTMEM_EMBEDDING_API_KEY=sk-...

# Server
RTMEM_SERVER_HOST=0.0.0.0
RTMEM_SERVER_PORT=8000
RTMEM_SERVER_CORS_ORIGINS=["*"]

# Authentication (disabled by default for local dev)
# RTMEM_AUTH_ENABLED=true
# RTMEM_API_KEYS=sk-rtmemory-key1,sk-rtmemory-key2